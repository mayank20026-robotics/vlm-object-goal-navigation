<?xml version="1.0" ?>
<robot name="Urdf_model" xmlns:xacro="http://www.ros.org/wiki/xacro">

<xacro:include filename="$(find Urdf_model_description)/urdf/materials.xacro" />
<xacro:include filename="$(find Urdf_model_description)/urdf/Urdf_model.trans" />
<xacro:include filename="$(find Urdf_model_description)/urdf/Urdf_model.gazebo" />
<link name="base_link">
  <inertial>
    <origin xyz="-0.01651719337439555 2.2672286204123524e-11 0.2557421146160457" rpy="0 0 0"/>
    <mass value="34.825589057280006"/>
    <inertia ixx="1.885448" iyy="2.195949" izz="1.014619" ixy="-0.0" iyz="-0.0" ixz="0.156258"/>
  </inertial>
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="file://$(find Urdf_model_description)/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="file://$(find Urdf_model_description)/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="oak_d_lite_cam_1">
  <inertial>
    <origin xyz="0.013719717938547857 -6.800219161924876e-16 -3.3306690738754696e-16" rpy="0 0 0"/>
    <mass value="0.28631007921750634"/>
    <inertia ixx="0.00015" iyy="2.6e-05" izz="0.000139" ixy="0.0" iyz="-0.0" ixz="0.0"/>
  </inertial>
  <visual>
    <origin xyz="-0.0975 0.0 -0.43" rpy="0 0 0"/>
    <geometry>
      <mesh filename="file://$(find Urdf_model_description)/meshes/oak_d_lite_cam_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="black"/>
  </visual>
  <collision>
    <origin xyz="-0.0975 0.0 -0.43" rpy="0 0 0"/>
    <geometry>
      <mesh filename="file://$(find Urdf_model_description)/meshes/oak_d_lite_cam_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="right_wheel_1">
  <inertial>
    <origin xyz="-4.1284089745879958e-16 -0.05031122829264573 3.8163916471489756e-16" rpy="0 0 0"/>
    <mass value="1.5492509150563074"/>
    <inertia ixx="0.00194" iyy="0.003217" izz="0.00194" ixy="-0.0" iyz="0.0" ixz="-0.0"/>
  </inertial>
  <visual>
    <origin xyz="0.0 0.14 -0.055" rpy="0 0 0"/>
    <geometry>
      <mesh filename="file://$(find Urdf_model_description)/meshes/right_wheel_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="black"/>
  </visual>
  <collision>
    <origin xyz="0.0 0.14 -0.055" rpy="0 0 0"/>
    <geometry>
      <mesh filename="file://$(find Urdf_model_description)/meshes/right_wheel_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="left_wheel_1">
  <inertial>
    <origin xyz="1.8338631500230479e-16 0.0503112282926472 -3.191891195797325e-16" rpy="0 0 0"/>
    <mass value="1.549250915056143"/>
    <inertia ixx="0.00194" iyy="0.003217" izz="0.00194" ixy="0.0" iyz="-0.0" ixz="0.0"/>
  </inertial>
  <visual>
    <origin xyz="0.0 -0.14 -0.055" rpy="0 0 0"/>
    <geometry>
      <mesh filename="file://$(find Urdf_model_description)/meshes/left_wheel_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="black"/>
  </visual>
  <collision>
    <origin xyz="0.0 -0.14 -0.055" rpy="0 0 0"/>
    <geometry>
      <mesh filename="file://$(find Urdf_model_description)/meshes/left_wheel_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="rplidar_a1_1">
  <inertial>
    <origin xyz="-2.0886070650760757e-15 2.3980817331903383e-16 0.012439024390243691" rpy="0 0 0"/>
    <mass value="0.7583411966684064"/>
    <inertia ixx="0.000271" iyy="0.000271" izz="0.000463" ixy="-0.0" iyz="0.0" ixz="-0.0"/>
  </inertial>
  <visual>
    <origin xyz="0.0595 -0.0 -0.635" rpy="0 0 0"/>
    <geometry>
      <mesh filename="file://$(find Urdf_model_description)/meshes/rplidar_a1_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="black"/>
  </visual>
  <collision>
    <origin xyz="0.0595 -0.0 -0.635" rpy="0 0 0"/>
    <geometry>
      <mesh filename="file://$(find Urdf_model_description)/meshes/rplidar_a1_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="laser_frame">
  <inertial>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <mass value="0.001"/>
    <inertia ixx="1e-6" iyy="1e-6" izz="1e-6" ixy="0" iyz="0" ixz="0"/>
  </inertial>
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <material name="black"/>
  </visual>
</link>

<link name="oak_data_frame"/>

<joint name="Rigid 5" type="fixed">
  <origin xyz="0.0975 0.0 0.43" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="oak_d_lite_cam_1"/>
</joint>

<joint name="Revolute 6" type="continuous">
  <origin xyz="0.0 -0.14 0.055" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="right_wheel_1"/>
  <axis xyz="-0.0 -1.0 0.0"/>
</joint>

<joint name="Revolute 7" type="continuous">
  <origin xyz="0.0 0.14 0.055" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="left_wheel_1"/>
  <axis xyz="0.0 1.0 0.0"/>
</joint>

<joint name="Rigid 8" type="fixed">
  <origin xyz="-0.0595 0.0 0.635" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="rplidar_a1_1"/>
</joint>

<joint name="oak_data_joint" type="fixed">
  <parent link="oak_d_lite_cam_1"/>
  <child link="oak_data_frame"/>
  <origin xyz="0 0 0" rpy="0 0.075 0"/> 
</joint>

<joint name="laser_joint" type="fixed">
  <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
  <parent link="rplidar_a1_1"/>
  <child link="laser_frame"/>
</joint>

</robot>
